# 카카오 로컬 API (장소 검색, 서버에서 사용) — 공개 저장소에 넣지 말 것
# 발급: https://developers.kakao.com > 내 애플리케이션 > 앱 키 > REST API 키
# 로컬 API 사용 전 앱 설정에서 "로컬" 권한 활성화 필요
KAKAO_REST_API_KEY=
# 구글 OAuth 로그인 (소셜 로그인)
# Google Cloud Console에서 OAuth 2.0 클라이언트(Web) 발급 필요
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Google OAuth Redirect URI와 동일해야 함
GOOGLE_OAUTH_REDIRECT_URI=

# ── 도메인 설정 ───────────────────────────────────────
# 백엔드 API 도메인 (Traefik Host 라우팅에 사용)
API_DOMAIN=api.shuttle-go.com
# 개발용 백엔드 API 도메인 (Webhook/외부 연동 시)
API_DEV_DOMAIN=api-dev.shuttle-go.com
# Grafana 대시보드 도메인
GRAFANA_DOMAIN=grafana.shuttle-go.com

# 로컬 Traefik 바인딩 포트 (호스트)
# - BACKEND_HTTP_PORT: http://localhost:<PORT>
# - BACKEND_HTTPS_PORT: https://localhost:<PORT>
# 기본값은 80 / 443
BACKEND_HTTP_PORT=80
BACKEND_HTTPS_PORT=443
# Prometheus 로컬 접근 포트 (http://localhost:<PORT>)
PROMETHEUS_HOST_PORT=9090

# 로컬 프론트엔드 정적 서버 포트 (run_dev.py)
FRONTEND_PORT=8080
# 로컬 프론트엔드가 호출할 API base 강제 오버라이드(선택)
# 예: https://api.example.com
# 비워두면 기존 동작(현재 host + BACKEND_HTTP/BACKEND_HTTPS_PORT)을 사용
FRONTEND_API_BASE=

# OTP(오픈트립플래너) 설정
# - prd(로컬 OTP 컨테이너 사용): OTP_BASE_URL=http://otp:8082
# - dev(원격 prd OTP 포트포워딩 사용): OTP_BASE_URL=http://host.docker.internal:8888
# - 호스트 직접 호출(prd): http://localhost:${OTP_HOST_PORT}
OTP_DATA_DIR=.
OTP_HOST_PORT=8082
OTP_BASE_URL=http://otp:8082
# 백엔드 실시간 도보 경로 OTP(plan) 요청 설정
# - OTP_PLAN_PATH: OTP GraphQL plan path (기본 /otp/gtfs/v1)
# - OTP_WALK_ENABLED: 1이면 선택한 노선 1건에 대해 도보 encoded polyline 요청, 0이면 비활성화(직선 fallback)
# - OTP_WALK_HTTP_TIMEOUT_SEC: 백엔드 -> OTP 요청 timeout(초)
# - OTP_WALK_DURATION_MULTIPLIER: OTP 도보 소요시간 보정 배율(표시용, 기본 1.25)
# - OTP_WALK_CACHE_SIZE: 좌표 구간 캐시 최대 개수
OTP_PLAN_PATH=/otp/gtfs/v1
OTP_WALK_ENABLED=1
OTP_WALK_HTTP_TIMEOUT_SEC=8
OTP_WALK_DURATION_MULTIPLIER=1.25
OTP_WALK_CACHE_SIZE=10000
# build_db.py에서 정류장 간 encoded polyline 계산 시 사용하는 OTP HTTP 주소
# 기본값: http://localhost:8888 /otp/gtfs/v1
OTP_HTTP_BASE_URL=http://localhost:8888
OTP_HTTP_PLAN_PATH=/otp/gtfs/v1
# build_db.py OTP 병렬 호출 설정
# - OTP_HTTP_MAX_PARALLEL: 동시 요청 개수 (기본 50)
# - OTP_HTTP_MAX_RPS: 초당 요청 상한(req/s, 기본 50)
OTP_HTTP_MAX_PARALLEL=50
OTP_HTTP_MAX_RPS=50
# build_db.py OTP 재시도 설정
# - OTP_HTTP_REQUEST_RETRIES: 요청 1건 내부 재시도 횟수 (기본 2)
# - OTP_HTTP_FAILED_RETRY_ROUNDS: 실패 구간 전체 재시도 라운드 수 (기본 2)
OTP_HTTP_REQUEST_RETRIES=2
OTP_HTTP_FAILED_RETRY_ROUNDS=2

# ── CORS ──────────────────────────────────────────────
# 허용 origin 목록 (쉼표 구분)
# 프론트엔드 도메인 + 필요한 dev origin 추가
# FRONTEND_PORT 변경 시 localhost/127.0.0.1 origin 포트도 맞춰서 수정
CORS_ORIGINS=https://shuttlego.github.io
# OAuth 콜백으로 되돌릴 프론트 URL 및 허용 origin
AUTH_FRONTEND_CALLBACK_URL=https://shuttle-go.com/auth-callback.html
AUTH_FRONTEND_ALLOWED_ORIGINS=https://shuttle-go.com,http://localhost:8080,http://127.0.0.1:8080

# ── Grafana ───────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme

# 앱 버전 (Prometheus 메타데이터에 표시)
APP_VERSION=1.0.0

# ── GitHub Issue 연동 (GitHub App) ───────────────────────
# GitHub App ID
GITHUB_APP_ID=
# GitHub App 설치(Installation) ID
GITHUB_INSTALLATION_ID=
# 제보를 저장할 저장소 owner / repo
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=
# GitHub App private key (멀티라인은 \n으로 이스케이프)
GITHUB_APP_PRIVATE_KEY=
# 또는 private key 파일 경로 사용 가능
GITHUB_APP_PRIVATE_KEY_PATH=
# GitHub webhook secret (X-Hub-Signature-256 검증용)
GITHUB_WEBHOOK_SECRET=
# 이슈 캐시 TTL(초), 등록 제한(초), 중복 차단 윈도우(초)
GITHUB_ISSUE_CACHE_TTL_SEC=60
ISSUE_SUBMIT_RATE_LIMIT_SEC=10
ISSUE_SUBMIT_DEDUPE_WINDOW_SEC=300

# ── 사용자 인증/히스토리 저장 ───────────────────────────
# 사용자 DB 경로 (route data.db와 분리)
USER_DB_PATH=/app/user-data/user.db
# 로그인 세션 유지 기간(일)
SESSION_TTL_DAYS=90
# 요청마다 세션 만료를 연장할지 여부(1/0)
SESSION_SLIDING=1
# 쿠키 정책(미설정 시 요청 보안상태에 따라 자동값 사용)
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_SECURE=
SESSION_COOKIE_SAMESITE=
# 키워드(장소) 검색 히스토리 자동 삭제 보관 개월 수
PLACE_SEARCH_HISTORY_RETENTION_MONTHS=1
# 노선 검색 히스토리 자동 삭제 보관 개월 수
ROUTE_SEARCH_HISTORY_RETENTION_MONTHS=6
# Grafana BI 대시보드용 스냅샷 DB 경로/갱신 주기(초)
USER_BI_DB_PATH=/app/user-bi-data/user-bi.db
BI_DB_SNAPSHOT_REFRESH_SEC=300
# 정리 루프 주기(초)
AUTH_CLEANUP_INTERVAL_SEC=3600
# 사용자 지표(로그인 사용자 수/DB 크기) 집계 주기(초)
AUTH_METRICS_REFRESH_SEC=300
# 탈퇴 사용자 GitHub 라벨 정리 주기/마감(시간)
GITHUB_CLEANUP_INTERVAL_SEC=60
GITHUB_CLEANUP_DEADLINE_HOURS=24
# 닉네임 길이 정책
AUTH_NICKNAME_MIN_LEN=2
AUTH_NICKNAME_MAX_LEN=20
