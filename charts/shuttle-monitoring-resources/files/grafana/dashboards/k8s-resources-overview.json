{
  "uid": "shuttle-k8s-resources",
  "title": "K8s Resources Overview",
  "tags": [
    "shuttle-go",
    "kubernetes",
    "resources"
  ],
  "timezone": "Asia/Seoul",
  "refresh": "15s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "editable": false,
  "schemaVersion": 39,
  "panels": [
    {
      "id": 1,
      "title": "Cluster CPU (usage vs allocatable)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{container!=\"\",container!=\"POD\",image!=\"\"}[$__rate_interval]))",
          "legendFormat": "cpu_usage",
          "refId": "A"
        },
        {
          "expr": "sum(kube_node_status_allocatable{resource=\"cpu\",unit=\"core\"})",
          "legendFormat": "cpu_allocatable",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cores"
        }
      }
    },
    {
      "id": 2,
      "title": "Cluster Memory (usage vs allocatable)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{container!=\"\",container!=\"POD\",image!=\"\"})",
          "legendFormat": "memory_usage",
          "refId": "A"
        },
        {
          "expr": "sum(kube_node_status_allocatable{resource=\"memory\",unit=\"byte\"})",
          "legendFormat": "memory_allocatable",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      }
    },
    {
      "id": 3,
      "title": "Running Pods by Namespace",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "sum by (namespace) (kube_pod_status_phase{phase=\"Running\"})",
          "legendFormat": "{{namespace}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Node CPU Utilization %",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "topk(10, 100 * (1 - avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[$__rate_interval]))))",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        }
      }
    },
    {
      "id": 5,
      "title": "Node Memory Utilization %",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "topk(10, 100 * (1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)))",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        }
      }
    },
    {
      "id": 6,
      "title": "Namespace CPU Top 10",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "topk(10, sum by (namespace) (rate(container_cpu_usage_seconds_total{container!=\"\",container!=\"POD\",image!=\"\"}[$__rate_interval])))",
          "legendFormat": "{{namespace}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cores"
        }
      }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "text": "Prometheus",
          "value": "Prometheus"
        },
        "hide": 2
      }
    ]
  }
}
