{
  "uid": "shuttle-k8s-workload",
  "title": "K8s Workload Health",
  "tags": [
    "shuttle-go",
    "kubernetes",
    "health"
  ],
  "timezone": "Asia/Seoul",
  "refresh": "15s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "editable": false,
  "schemaVersion": 39,
  "panels": [
    {
      "id": 1,
      "title": "CrashLoopBackOff Pods",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "sum(kube_pod_container_status_waiting_reason{reason=\"CrashLoopBackOff\"})",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Pods Not Ready",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "sum(kube_pod_status_ready{condition=\"false\"})",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Unavailable Deployment Replicas",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "sum(kube_deployment_status_replicas_unavailable)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Job Failures",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "sum(kube_job_status_failed)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Top Restarted Pods (5m)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "topk(10, sum by (namespace,pod) (increase(kube_pod_container_status_restarts_total[5m])))",
          "legendFormat": "{{namespace}}/{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Pods by Phase",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "sum by (phase) (kube_pod_status_phase)",
          "legendFormat": "{{phase}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Deployments with Unavailable Replicas",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 12
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "sum by (namespace,deployment) (kube_deployment_status_replicas_unavailable > 0)",
          "legendFormat": "{{namespace}}/{{deployment}}",
          "refId": "A"
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "text": "Prometheus",
          "value": "Prometheus"
        },
        "hide": 2
      }
    ]
  }
}
