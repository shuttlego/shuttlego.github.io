{
  "uid": "shuttle-go-main",
  "title": "ShuttleGo - API Monitoring",
  "tags": [
    "shuttle-go",
    "backend"
  ],
  "timezone": "Asia/Seoul",
  "refresh": "10s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "editable": true,
  "schemaVersion": 39,
  "panels": [
    {
      "type": "row",
      "title": "요청 개요",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false
    },
    {
      "id": 1,
      "title": "모든 요청 req/s (경로별, stacked)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "sum by (endpoint) (rate(shuttle_http_requests_total{endpoint!~\"^/(health|metrics)$\"}[$__rate_interval])) > 0",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 35,
            "showPoints": "never",
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          }
        }
      }
    },
    {
      "id": 2,
      "title": "모든 요청 HTTP 상태 코드 req/s",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "sum by (status) (rate(shuttle_http_requests_total{endpoint!~\"^/(health|metrics)$\"}[$__rate_interval]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        }
      }
    },
    {
      "id": 3,
      "title": "모든 요청 크기 합계 (이번 달 누적)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 9
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "sum(increase(shuttle_http_request_size_bytes_total{endpoint!~\"^/(health|metrics)$\"}[$__range]))",
          "legendFormat": "request bytes (month-to-date)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "never"
          }
        }
      },
      "timeFrom": "now/M"
    },
    {
      "id": 4,
      "title": "모든 응답 크기 합계 (이번 달 누적)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 9
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "sum(increase(shuttle_http_response_size_bytes_total{endpoint!~\"^/(health|metrics)$\"}[$__range]))",
          "legendFormat": "response bytes (month-to-date)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "never"
          }
        }
      },
      "timeFrom": "now/M"
    },
    {
      "type": "row",
      "title": "비즈니스 메트릭",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 17
      },
      "collapsed": false
    },
    {
      "id": 5,
      "title": "일반 API req/s (issue/auth-callback/otp 제외, 경로별)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 18
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "sum by (endpoint) (rate(shuttle_http_requests_total{endpoint=~\"/api/.*\",endpoint!~\"/api/issues($|/.*)|/api/github/webhook|/api/auth/google/callback|/api/shuttle/walk-path|/api/otp($|/.*)\",endpoint!=\"/api/_unmatched\"}[$__rate_interval])) > 0",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "showPoints": "never"
          }
        }
      }
    },
