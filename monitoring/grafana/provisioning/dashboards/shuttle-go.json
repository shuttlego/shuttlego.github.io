    {
      "id": 26,
      "title": "로그인/비로그인 API 요청 비율",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 58
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "sum(rate(shuttle_api_requests_by_auth_total{auth_state=\"authenticated\"}[$__rate_interval])) / clamp_min(sum(rate(shuttle_api_requests_by_auth_total[$__rate_interval])), 1e-9)",
          "legendFormat": "로그인",
          "refId": "A"
        },
        {
          "expr": "sum(rate(shuttle_api_requests_by_auth_total{auth_state=\"anonymous\"}[$__rate_interval])) / clamp_min(sum(rate(shuttle_api_requests_by_auth_total[$__rate_interval])), 1e-9)",
          "legendFormat": "비로그인",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 60,
            "showPoints": "never",
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          }
        }
      }
    },
    {
      "id": 27,
