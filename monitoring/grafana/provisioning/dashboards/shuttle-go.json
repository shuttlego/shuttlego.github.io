    {
      "id": 9,
      "title": "일반 API latency (issue/auth-callback/otp 제외, p50/p90/p99)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 26
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(shuttle_http_request_duration_seconds_bucket{endpoint=~\"/api/.*\",endpoint!~\"/api/issues($|/.*)|/api/github/webhook|/api/auth/google/callback|/api/shuttle/walk-path|/api/otp($|/.*)\",endpoint!=\"/api/_unmatched\"}[$__rate_interval])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.90, sum by (le) (rate(shuttle_http_request_duration_seconds_bucket{endpoint=~\"/api/.*\",endpoint!~\"/api/issues($|/.*)|/api/github/webhook|/api/auth/google/callback|/api/shuttle/walk-path|/api/otp($|/.*)\",endpoint!=\"/api/_unmatched\"}[$__rate_interval])))",
          "legendFormat": "p90",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(shuttle_http_request_duration_seconds_bucket{endpoint=~\"/api/.*\",endpoint!~\"/api/issues($|/.*)|/api/github/webhook|/api/auth/google/callback|/api/shuttle/walk-path|/api/otp($|/.*)\",endpoint!=\"/api/_unmatched\"}[$__rate_interval])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        }
      }
    },
