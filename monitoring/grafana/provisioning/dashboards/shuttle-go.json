      "targets": [
        {
          "expr": "sum by (endpoint) (rate(shuttle_http_requests_total{endpoint=~\"/api/shuttle/walk-path|/api/otp($|/.*)\"}[$__rate_interval])) > 0",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
