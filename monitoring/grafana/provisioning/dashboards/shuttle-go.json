      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le, endpoint) (rate(shuttle_http_request_duration_seconds_bucket{endpoint=~\"/api/.*\",endpoint!~\"/api/issues($|/.*)|/api/github/webhook|/api/auth/google/callback|/api/shuttle/walk-path|/api/otp($|/.*)\",endpoint!=\"/api/_unmatched\"}[$__rate_interval])))",
